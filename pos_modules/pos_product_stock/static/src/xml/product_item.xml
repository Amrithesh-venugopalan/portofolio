<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="point_of_sale.ProductCard" t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('product-content')]" position="inside">
            <t t-if="value.display_stock">
                <t t-if="pos.config.location_from == 'all_warehouse'">
                    <t t-if="pos.config.stock_product == 'incoming_qty'">
                        <div class="product-cart-qty position-absolute top-0 start-0 m-1 px-2 rounded text-white fs-5 fw-bolder" style="background-color:rgb(195, 216, 195)">
                            <t t-esc="state.incoming_qty"/>
                        </div>
                    </t>
                    <t t-if="pos.config.stock_product == 'outgoing_qty'">
                        <div class="product-cart-qty position-absolute top-0 start-0 m-1 px-2 rounded text-white fs-5 fw-bolder" style="background-color:rgb(195, 216, 195)">
                            <t t-esc="state.outgoing_qty"/>
                        </div>
                    </t>
                    <t t-if="pos.config.stock_product == 'on_hand'">
                        <div class="product-cart-qty position-absolute top-0 start-0 m-1 px-2 rounded text-white fs-5 fw-bolder" style="background-color:rgb(195, 216, 195)">
                            <t t-esc="state.qty_available"/>
                        </div>
                    </t>
                </t>
                <t t-if="pos.config.location_from == 'current_warehouse'">
                    <t t-if="pos.config.stock_product == 'incoming_qty'">
                        <div class="product-cart-qty position-absolute top-0 start-0 m-1 px-2 rounded text-white fs-5 fw-bolder" style="background-color:rgb(195, 216, 195)">
                            <t t-esc="props.incoming_loc"/>
                        </div>
                    </t>
                    <t t-if="pos.config.stock_product == 'outgoing_qty'">
                        <div class="product-cart-qty position-absolute top-0 start-0 m-1 px-2 rounded text-white fs-5 fw-bolder" style="background-color:rgb(195, 216, 195)">
                            <t t-esc="props.outgoing"/>
                        </div>
                    </t>
                    <t t-if="pos.config.stock_product == 'on_hand'">
                        <div class="product-cart-qty position-absolute top-0 start-0 m-1 px-2 rounded text-white fs-5 fw-bolder" style="background-color:rgb(195, 216, 195)">
                            <t t-out="props.on_hand"/>
                        </div>
                    </t>
                </t>
            </t>
        </xpath>
    </t>
</templates>