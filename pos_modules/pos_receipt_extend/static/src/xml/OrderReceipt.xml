<?xml version="1.0" encoding="UTF-8"?>
<!--To add the customer details in the settings page-->
<templates id="template" xml:space="preserve">
    <t t-name="OrderReceipt" t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//div[@t-if='order.partner_id.name']" position="replace">
            <div t-if="order.config.customer_name and order.partner_id.name">Customer Name:
                <t t-out="order.partner_id.name"/>
            </div>
            <span t-else="">
                <div t-if="order.partner_id.name">
                    <t t-if="order.partner_id.parent_name">
                        <span t-esc="order.partner_id.parent_name"/>,
                    </t>
                    <span t-esc="order.partner_id.name"/>
                </div>
            </span>
        </xpath>
        <xpath expr="//div[@t-if='order.partner_id.pos_contact_address']" position="replace">
            <div t-if="order.config.customer_address and order.partner_id.pos_contact_address">Customer Address:
                <t t-out="order.partner_id.pos_contact_address"/>
            </div>
            <span t-else="">
                <div t-if="order.partner_id.pos_contact_address">
                    <span t-esc="order.partner_id.pos_contact_address"/>
                </div>
            </span>
        </xpath>
        <xpath expr="//div[@t-if='order.partner_id.vat']" position="replace">
            <div t-if="order.config.customer_vat and order.partner_id.vat">Customer Vat:
                <t t-out="order.partner_id.vat"/>
            </div>
            <span t-else="">
                <div t-if="order.partner_id.vat">
                    <span t-esc="order.partner_id.vat"/>
                </div>
            </span>
        </xpath>
        <xpath expr="//div[@t-if='order.partner_id']" position="after">
            <span t-if="order.config.customer_mobile and order.partner_id.mobile" class="pos-receipt-customer">Customer Mobile:
                <t t-out="order.partner_id.mobile"/>
            </span>
            <span t-if="order.config.customer_phone and order.partner_id.phone" class="pos-receipt-customer">Customer Phone:
                <t t-out="order.partner_id.phone"/>
            </span>
            <span t-if="order.config.customer_email and order.partner_id.email" class="pos-receipt-customer">Customer Email:
                <t t-out="order.partner_id.email"/>
            </span>
        </xpath>
    </t>
</templates>
